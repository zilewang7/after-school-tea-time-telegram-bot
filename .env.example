# ===== Bot =====
BOT_TOKEN=
BOT_USER_ID=
BOT_NAME=
BOT_USER_NAME=

# ===== AI platforms =====
OPENAI_API_KEY=
OPENAI_API_URL=
# Gemini runs on Vertex AI. Express mode (apiKey) by default; auto-switches to
# full Vertex (ADC) when a real ./gcp-sa.json is present — required for GCS.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
DEEPSEEK_API_URL=
DEEPSEEK_API_KEY=
PICZIT_ENDPOINT=

# ===== Behavior =====
SYSTEM_PROMPT=
DEFAULT_MODEL=
MCP_SERVERS=

# ===== Network =====
# SOCKS5 proxy for the cloud Bot API (bypassed when TG_LOCAL_API_ROOT is set).
BOT_PROXY=

# ===== Optional services (docker compose profiles) =====
# Comma-separated profiles to start. 'tgs' = tgs-converter (animated-sticker
# rendering, recommended default). Add 'bigfile' to also run the local Bot API
# server for >20MB media, e.g.  COMPOSE_PROFILES=tgs,bigfile
COMPOSE_PROFILES=tgs
TGS_CONVERTER_URL=http://tgs-converter:8080

# ===== Large media (optional; needs 'bigfile' in COMPOSE_PROFILES) =====
# Default (the four vars below empty): cloud getFile 20MB, Gemini express,
# files >20MB skipped — identical to current behavior.
# To enable end-to-end:
#   1. add bigfile into like COMPOSE_PROFILES=tgs,bigfile  (above)
#   2. drop a real service-account JSON at ./gcp-sa.json
#   3. set GOOGLE_CLOUD_PROJECT (above) to that SA's project
TG_LOCAL_API_ROOT=http://telegram-bot-api:8081
TG_API_ID=
TG_API_HASH=
GCS_BUCKET=
